---
const currentYear = new Date().getFullYear();
---

<footer style="
  margin-top: 48px;
  padding: 32px 0;
  border-top: 1px solid var(--border);
  background: var(--bg2);
">
  <div style="max-width:1400px;margin:0 auto;padding:0 24px;">
    {/* 主要内容区 */}
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:32px;margin-bottom:32px;">
      
      {/* 关于博客 */}
      <div>
        <h3 style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px;">
          📝 关于 Rublog
        </h3>
        <p style="font-size:13px;line-height:1.6;color:var(--text2);margin-bottom:12px;">
          使用 GitHub Actions 自动化发布 Markdown 文章到 WordPress 的技术博客。
          专注于工业自动化、Web开发和效率工具分享。
        </p>
        <div style="display:flex;gap:8px;">
          <a 
            href="https://github.com/xinyu3ru/rublog_publish" 
            target="_blank"
            style="padding:6px 12px;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:12px;text-decoration:none;transition:all 0.2s;"
            onmouseover="this.style.borderColor='var(--blue)'"
            onmouseout="this.style.borderColor='var(--border)'"
          >
            GitHub
          </a>
          <a 
            href="https://rxx0.com" 
            target="_blank"
            style="padding:6px 12px;background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text);font-size:12px;text-decoration:none;transition:all 0.2s;"
            onmouseover="this.style.borderColor='var(--blue)'"
            onmouseout="this.style.borderColor='var(--border)'"
          >
            主站
          </a>
        </div>
      </div>
      
      {/* 快速链接 */}
      <div>
        <h3 style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px;">
          🔗 快速链接
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:8px;">
          {[
            { name: '所有文章', url: 'https://rxx0.com' },
            { name: '关于我', url: 'https://rxx0.com/about' },
            { name: '友情链接', url: 'https://www.kefuxx.com/tools' },
            { name: 'xlsx2vcf转换器', url: 'https://xlsx2vcf.kefuxx.com/' },
            { name: 'PLC exporter', url: 'https://exporter.kefuxx.com/' },
            { name: '罩杯计算器', url: 'https://bra.kefuxx.com/' }
          ].map(link => (
            <li>
              <a 
                href={link.url} 
                target="_blank"
                style="font-size:13px;color:var(--text2);text-decoration:none;transition:color 0.2s;"
                onmouseover="this.style.color='var(--blue)'"
                onmouseout="this.style.color='var(--text2)'"
              >
                → {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      {/* 技术栈 */}
      <div>
        <h3 style="font-size:14px;font-weight:600;color:var(--text);margin-bottom:12px;">
          ⚡ 技术栈
        </h3>
        <div style="display:flex;flex-wrap:wrap;gap:6px;">
          {['Astro v6', 'GitHub Actions', 'TypeScript', 'Python', 'WordPress REST API'].map(tech => (
            <span style="
              font-size:11px;
              background:var(--bg);
              color:var(--text2);
              padding:4px 10px;
              border-radius:12px;
              border:1px solid var(--border);
            ">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
    
    {/* 版权信息 */}
    <div style="
      border-top:1px solid var(--border);
      padding-top:20px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      flex-wrap:wrap;
      gap:16px;
    ">
      <div style="font-size:12px;color:var(--text2);">
        © {currentYear} Rublog Publish · 
        <a href="https://beian.miit.gov.cn/" target="_blank" style="color:var(--blue);text-decoration:none;">
          蒙ICP备20030078号
        </a>
      </div>
      <div style="font-size:12px;color:var(--text2);">
        Powered by Astro & WordPress · 
        <span id="runtime"></span>
      </div>
    </div>
  </div>
</footer>

<script>
  // 运行时间计算
  document.addEventListener('DOMContentLoaded', () => {
    const startDate = new Date('2024-07-24');
    const now = new Date();
    const diff = now.getTime() - startDate.getTime();
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    
    const runtimeEl = document.getElementById('runtime');
    if (runtimeEl) {
      runtimeEl.textContent = `已运行 ${days} 天`;
    }
  });
</script>