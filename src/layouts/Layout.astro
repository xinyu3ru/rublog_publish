---
interface Props {
  title?: string;
}
const { title = 'Rublog Publish' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN" class="light"> <!-- ✅ 初始为 light -->
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    /* 基础变量 - 明亮模式 */
    :root {
      --bg: #ffffff;
      --bg2: #f6f8fa;
      --border: #d0d7de;
      --text: #1f2328;
      --text2: #656d76;
      --blue: #0969da;
      --blue-bg: rgba(9, 105, 218, 0.1);
    }
    
    /* 暗黑模式变量 */
    html.dark {
      --bg: #0d1117;
      --bg2: #161b22;
      --border: #30363d;
      --text: #e6edf3;
      --text2: #8b949e;
      --blue: #58a6ff;
      --blue-bg: rgba(56, 139, 253, 0.15);
    }
    
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background-color: var(--bg);
      color: var(--text);
      line-height: 1.6;
      transition: background-color 0.3s, color 0.3s;
    }
    
    /* ✅ 三栏布局 */
    .layout-container {
      display: flex;
      min-height: 100vh;
      max-width: 1600px;
      margin: 0 auto;
      padding: 0 24px;
    }
    
    .left-sidebar {
      width: 280px;
      flex-shrink: 0;
      position: sticky;
      top: 24px;
      height: calc(100vh - 48px);
      overflow-y: auto;
      padding: 24px 16px 24px 0;
      border-right: 1px solid var(--border);
    }
    
    .main-content {
      flex: 1;
      min-width: 0;
      padding: 32px 40px;
      max-width: 1000px;
      margin: 0 auto;
    }
    
    /* ✅ 右侧边栏 - 调窄到 180px */
    .right-sidebar {
      width: 180px; /* ✅ 这里调窄 */
      flex-shrink: 0;
      position: sticky;
      top: 24px;
      height: calc(100vh - 48px);
      overflow-y: auto;
      padding: 24px 0 24px 16px;
      border-left: 1px solid var(--border);
    }
    
    /* 美化滚动条 */
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    
    ::-webkit-scrollbar-track {
      background: transparent;
    }
    
    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 3px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
      background: var(--text2);
    }
    
    * {
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    
    @media (max-width: 1280px) {
      .layout-container {
        padding: 0 16px;
      }
      
      .left-sidebar,
      .right-sidebar {
        display: none;
      }
      
      .main-content {
        padding: 24px 0;
        max-width: 100%;
      }
    }
  </style>
</head>
<body>
  <div class="layout-container">
    <slot />
  </div>
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const savedTheme = localStorage.getItem('theme') || 'light';
      document.documentElement.className = savedTheme;
    });
  </script>
</body>
</html>